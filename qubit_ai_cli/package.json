{
  "name": "qubit_ai_cli",
  "version": "1.0.0",
  "type": "module",
  "description": "Interactive chat CLI for Qubit AI - quantum-inspired text generation",
  "main": "./dist/index.js",
  "bin": {
    "qubit-chat": "./dist/bin/cli.js"
  },
  "scripts": {
    "dev": "tsx src/bin/cli.ts",
    "build": "tsc",
    "start": "node dist/bin/cli.js",
    "hybrid": "node dist/bin/hybrid-cli.js",
    "dev:hybrid": "tsx src/bin/hybrid-cli.ts",
    "multi-agent": "node dist/bin/multi-agent-cli.js",
    "dev:multi-agent": "tsx src/bin/multi-agent-cli.ts",
    "qbnn": "node dist/bin/qbnn-cli.js",
    "dev:qbnn": "tsx src/bin/qbnn-cli.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "qubit",
    "ai",
    "cli",
    "chat",
    "interactive",
    "generative-ai",
    "text-generation"
  ],
  "author": "tapiocaTakeshi",
  "license": "MIT",
  "dependencies": {
    "qubit_ai": "^4.0.5",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
